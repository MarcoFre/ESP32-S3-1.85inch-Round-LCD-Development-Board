  - id: ${wake_word_flow_active_id}
    type: bool
    restore_value: no
    initial_value: "false"

  - id: ${volume_bar_until_id}
    type: uint32_t
    restore_value: no
    initial_value: "0"

  - id: ${display_emotion_mode_id}
    type: int
    restore_value: yes
    initial_value: "0"

  - id: ${display_awake_until_id}
    type: uint32_t
    restore_value: no
    initial_value: "0"

  - id: ${va_timer_total_seconds_id}
    type: uint32_t
    restore_value: no
    initial_value: "0"

  - id: ${va_timer_seconds_left_id}
    type: uint32_t
    restore_value: no
    initial_value: "0"

  - id: ${va_timer_last_tick_ms_id}
    type: uint32_t
    restore_value: no
