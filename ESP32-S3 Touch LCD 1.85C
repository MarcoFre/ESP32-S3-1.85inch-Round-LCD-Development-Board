# ======================================================
# Waveshare ESP32-S3 Touch LCD 1.85C
# HackMyHome
# ======================================================

substitutions:
  device_name: home-assistant-voice-speaker-02
  friendly:   "Speaker-04"
  fw_version: "1.0.0"

  # -------- SECURITY --------
  password:   "WiFi Password"
  api_key:    "CiNgQqOfbti7EO2MJWx+lGptEgBe9O2YHfdgdts26U4="
  ota_key:    "777947954e176a894bb4402f586e789c"

  # -------- WiFi --------
  ip:         "192.168.xxx.xxx"
  gateway:    "192.168.xxx.xxx"
  subnet:     "255.255.255.0"
  dns:        "192.168.xxx.xxx"
  ssid:       "WiFi SSID"  

  ble_sync_uuid: "7f4c8f1e-4f22-4d8f-9d8b-6c7a9f1a2026"
  ble_sync_major: "2026"
  my_ble_minor: "2"
  ble_peer_minor: "1"

  # -------- Voice Assistant Phases --------
  voice_assist_idle_phase_id:                   '1' # ready to be triggered by a wake word
  voice_assist_waiting_for_command_phase_id:    '2' # waiting for a voice command after wake word
  voice_assist_listening_for_command_phase_id:  '3' # actively listening to user speech
  voice_assist_thinking_phase_id:               '4' # processing the command
  voice_assist_replying_phase_id:               '5' # replying to the command
  voice_assist_not_ready_phase_id:             '10' # not ready
  voice_assist_error_phase_id:                 '11' # encountered an error

  # -------- Display Waveshare ESP32-S3 Touch LCD 1.85C - ST77916 QSPI --------
  display_clk_pin: GPIO40
  display_qspi_d0: GPIO46
  display_qspi_d1: GPIO45
  display_qspi_d2: GPIO42
  display_qspi_d3: GPIO41
  display_cs_pin:  GPIO21
  display_bl_pin:  GPIO5
  display_reset_expander_pin: "1"

  # -------- Touch CST816T --------
  touch_interrupt_pin: GPIO4
  touch_address: "0x15"
  touch_reset_expander_pin: "0"

  # -------- Audio / I2S pins - Waveshare ESP32-S3 Touch LCD 1.85C --------
  i2c_scl:          GPIO10
  i2c_sda:          GPIO11
  i2s_mclk:         GPIO2
  i2s_bclk:         GPIO48
  i2s_lrclk:        GPIO38
  i2s_dout:         GPIO47
  i2s_din:          GPIO39

  # ---------------- BATTERY ADC ----------------
  battery_adc_pin: GPIO8

  # -------- Codec --------
  es8311_address:   "0x18"
  es7210_address:   "0x40"

  # -------- Amplifier --------
  amp_ctrl:         GPIO15

  # -------- Microphone channel lookup --------
  mic_channel_0: 'left'
  mic_channel_1: 'right'
  mic_channel_2: 'stereo'

  # -------- Audio tuning --------
  which_mic:            0          # 0=left, 1=right, 2=stereo
  i2s_sample_rate:      16000
  i2s_bits_per_sample:  32
  i2s_mode_mic:         primary
  i2s_mode_speaker:     secondary
  i2s_use_apll:         true
  i2s_bps_spk:          16bit
  i2s_bps_mic:          16bit
  i2s_mclk_multiple:  256

  # ======================================================
  # ENTITY / COMPONENT IDS
  # ======================================================
  # -------- Core IDs --------
  wifi_component_id:  wifi_id
  api_component_id:   api_id
  ota_component_id:   ota_esphome
  rtc_id: rtc

  # -------- I2C / Expander --------
  i2c_bus_id:     internal_i2c
  io_expander_id: ioexp

  # -------- Display / Touch --------
  display_id:                   oled
  display_backlight_output_id:  display_backlight_output
  display_backlight_id:         display_backlight
  touch_panel_id:               touch_panel

  # -------- Audio / Voice Assistant --------
  media_player_id:    external_media_player
  voice_assistant_id: va
  micro_wake_word_id: mww
  audio_adc_id:       adc_mic
  va_microphone_id:   va_mic

  # -------- Speaker / Mixer / Resampler IDs --------
  hw_speaker_id: hw_speaker
  media_mixer_input_id: media_mixer_input
  announcement_mixer_input_id: announcement_mixer_input

  # -------- Switch IDs --------
  mic_mute_switch_id:       mic_mute_switch
  wake_sound_switch_id:     wake_sound
  timer_ringing_switch_id:  timer_ringing
  antifurto_switch_id:      sw_antifurto
  alarm_on_switch_id:       alarm_on

  # -------- Number / Select / Text IDs --------
  mic_gain_number_id:             mic_gain_db
  va_gain_factor_number_id:       va_gain_factor
  va_noise_suppression_number_id: va_noise_suppression
  alarm_time_text_id:             alarm_time
  current_time_text_id:           current_time
  alarm_action_select_id:         alarm_action

  # -------- Sensor / Text Sensor IDs --------
  next_timer_sensor_id:       next_timer
  next_timer_name_sensor_id:  next_timer_name

  # -------- Audio File IDs --------
  mute_switch_on_sound_id:        mute_switch_on_sound
  mute_switch_off_sound_id:       mute_switch_off_sound
  timer_finished_sound_id:        timer_finished_sound
  wake_word_triggered_sound_id:   wake_word_triggered_sound

  # -------- Global IDs --------
  touch_x_id: touch_x
  touch_y_id: touch_y
  touch_counter_id: touch_counter
  local_cmd_code_id: local_cmd_code

  display_startled_until_id: display_startled_until
  display_awake_until_id: display_awake_until
  display_emotion_mode_id: display_emotion_mode
  volume_bar_until_id: volume_bar_until

  antifurto_alarm_in_corso_id: antifurto_alarm_in_corso
  wake_word_flow_active_id: wake_word_flow_active

  va_timer_total_seconds_id: va_timer_total_seconds
  va_timer_seconds_left_id: va_timer_seconds_left
  va_timer_last_tick_ms_id: va_timer_last_tick_ms
  va_timer_active_display_id: va_timer_active_display
  va_timer_name_display_id: va_timer_name_display

  mic_gain_saved_id: mic_gain_saved

  led_ring_color_r_id: led_ring_color_r
  led_ring_color_g_id: led_ring_color_g
  led_ring_color_b_id: led_ring_color_b

  init_in_progress_id: init_in_progress
  improv_ble_in_progress_id: improv_ble_in_progress

  voice_assistant_phase_global_id: voice_assistant_phase
  voice_assistant_phase_prev_id: voice_assistant_phase_prev

  saved_alarm_time_id: saved_alarm_time
  saved_time_zone_id: saved_time_zone
  saved_alarm_action_id: saved_alarm_action

  first_active_timer_id: first_active_timer
  is_timer_active_id: is_timer_active

  fw_update_check_enabled_id: fw_update_check_enabled
  fw_update_available_id: fw_update_available
  fw_latest_version_id: fw_latest_version

  va_modalita_continua_id: va_modalita_continua
  va_ultimo_input_ms_id: va_ultimo_input_ms

  # -------- Script IDs --------
  script_va_local_volume_up_id: va_local_volume_up
  script_va_local_volume_down_id: va_local_volume_down
  script_va_local_mute_on_id: va_local_mute_on
  script_va_local_mute_off_id: va_local_mute_off
  script_va_local_silent_on_id: va_local_silent_on
  script_va_stop_id: va_stop
  script_va_local_alarm_on_id: va_local_alarm_on
  script_va_local_alarm_off_id: va_local_alarm_off
  script_start_va_from_wake_word_id: start_va_from_wake_word
  script_ensure_wake_word_running_id: ensure_wake_word_running
  script_ring_timer_id: ring_timer
  script_enable_repeat_one_id: enable_repeat_one
  script_disable_repeat_id: disable_repeat
  script_play_sound_id: play_sound
  script_fetch_first_active_timer_id: fetch_first_active_timer
  script_check_if_timers_active_id: check_if_timers_active
  script_activate_stop_word_once_id: activate_stop_word_once
  script_check_alarm_id: check_alarm
  script_send_alarm_event_id: send_alarm_event
  script_send_tts_uri_event_id: send_tts_uri_event
  script_send_stt_text_event_id: send_stt_text_event
  script_publish_current_time_id: publish_current_time
  script_check_firmware_version_id: check_firmware_version
  script_flash_ring_id: flash_ring
  script_antifurto_trigger_id: antifurto_trigger
  script_control_brightness_apply_id: control_brightness_apply
  script_control_start_va_id: control_start_va

  # -------- Additional Component / Entity IDs --------
  display_qspi_id: display_qspi
  i2s_output_id: i2s_output
  i2s_input_id: i2s_input
  audio_dac_id: es8311_dac
  microphone_id: i2s_mics
  i2s_audio_speaker_id: i2s_audio_speaker
  audio_mixer_speaker_id: audio_mixer_speaker
  media_resampler_id: media_resampler
  announcement_resampler_id: announcement_resampler
  amp_enable_switch_id: amp_enable_8
  mute_sound_switch_id: mute_sound
  va_continuous_mode_switch_id: sw_modalita_va_continua
  fw_update_check_switch_id: sw_fw_update_check
  noise_threshold_number_id: noise_threshold_db
  ambient_noise_sensor_id: ambient_noise_db
  playback_meter_sensor_id: playback_meter
  playback_rms_sensor_id: playback_rms
  playback_peak_sensor_id: playback_peak
  noise_detected_binary_sensor_id: noise_detected
  emotion_select_id: emotion_select
  logger_select_id: logger_select
  factory_reset_button_id: factory_reset_button
  restart_button_id: restart_button
  font_header_id: font_header
  font_timer_big_id: font_timer_big
  font_timer_small_id: font_timer_small
  wake_word_okay_nabu_model_id: okay_nabu
  wake_word_kenobi_model_id: kenobi
  wake_word_hey_jarvis_model_id: hey_jarvis
  wake_word_stop_model_id: stop

 # -------- Local Intent --------
  up:               "alza"
  increase:         "aumenta"
  down:             "abbassa"
  reduce:           "riduci"
  volume:           "volume"

  enable:           "attiva"
  disable:          "disattiva"
  put:              "metti"
  remove:           "togli"
  allow:            "abilita"
  deny:             "disabilita"

  silent_mode:      "modalita silenziosa"
  silent_mode_acc:  "modalità silenziosa"

  arm:              "inserisci"
  disarm:           "disinserisci"
  alarm:            "antifurto"

